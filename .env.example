# Copy to .env and fill in values for local development.
# GitHub Actions uses repository secrets with the same names.

OPENWEATHER_API_KEY=your_openweather_api_key
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=aqi_predictor

# Optional — enables Hugging Face Hub model upload/download
HF_TOKEN=hf_your_token
HF_REPO_ID=your-username/aqi-karachi-models
